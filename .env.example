# Plantilla de variables de entorno de Avimol.
# Copia este archivo como .env.local y completa con los valores reales.
# .env.local está en .gitignore — NUNCA subir credenciales al repo.
#
# IMPORTANTE: usamos el MISMO proyecto de Supabase que Lipgo (misma URL,
# misma service role key), pero todas las tablas de Avimol viven en el
# esquema `avimol`, no en `public`. Para que el cliente pueda consultarlo
# hay que agregar "avimol" a Settings → API → "Exposed schemas" en el
# panel de Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# Secreto para firmar los JWT de sesión de avimol.usuarios (NO es Supabase
# Auth). Genera uno largo y aleatorio, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AVIMOL_JWT_SECRET=
